{
  "name": "@the-rabbit-hole-tech/docs-theme",
  "version": "0.0.0",
  "description": "Shared Docusaurus theme for the rabbit hole docs sites",
  "author": "Shane",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/config.d.mts",
        "default": "./dist/config.mjs"
      },
      "require": {
        "types": "./dist/config.d.cts",
        "default": "./dist/config.cjs"
      }
    },
    "./landing": {
      "import": {
        "types": "./dist/components/Landing/index.d.mts",
        "default": "./dist/components/Landing/index.mjs"
      },
      "require": {
        "types": "./dist/components/Landing/index.d.cts",
        "default": "./dist/components/Landing/index.cjs"
      }
    },
    "./styles/custom.css": "./styles/custom.css",
    "./static/img/favicon.svg": "./static/img/favicon.svg"
  },
  "files": [
    "dist",
    "src/theme",
    "src/components",
    "styles",
    "static"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-rabbit-hole-tech/docs-theme.git"
  },
  "homepage": "https://github.com/the-rabbit-hole-tech/docs-theme#readme",
  "bugs": {
    "url": "https://github.com/the-rabbit-hole-tech/docs-theme/issues"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist docs coverage",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docs": "typedoc"
  },
  "peerDependencies": {
    "@docusaurus/core": ">=3.0.0",
    "@docusaurus/types": ">=3.0.0",
    "prism-react-renderer": ">=2.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@docusaurus/core": "^3.7.0",
    "@docusaurus/module-type-aliases": "^3.7.0",
    "@docusaurus/theme-classic": "^3.7.0",
    "@docusaurus/tsconfig": "^3.7.0",
    "@docusaurus/types": "^3.7.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "prism-react-renderer": "^2.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsdown": "^0.22.0",
    "typedoc": "^0.28.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@docusaurus/theme-mermaid": "^3.10.1"
  }
}
